@model List<Major>

<h1>Student List Page</h1>
<table class="table table-striped table-hover">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Department</th>
        <th>Credits Completed</th>
        <th>CGPA</th>
    </tr>
    @foreach(var major in Model)
    {
        <tr>
            <td>@major.ID</td>
            <td>@major.Name</td>
            <td>@major.Department</td>
            <td>@major.Credits</td>
            <td>@major.CGPA</td>
        </tr>
    }
</table>